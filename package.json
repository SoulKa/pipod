{
  "name": "pi-darts",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  },
  "scripts": {
    "dev:board": "yarn workspace @pi-darts/board dev",
    "dev:console": "yarn workspace @pi-darts/console dev",
    "dev:server": "yarn workspace @pi-darts/server dev",
    "preview:board": "yarn workspace @pi-darts/board preview",
    "preview:console": "yarn workspace @pi-darts/console preview",
    "start:server": "yarn workspace @pi-darts/server start",
    "build": "yarn type-check && yarn workspace @pi-darts/board build-only && yarn workspace @pi-darts/console build-only",
    "type-check": "yarn workspace @pi-darts/shared type-check && yarn workspace @pi-darts/server type-check && yarn workspace @pi-darts/board type-check && yarn workspace @pi-darts/console type-check",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown"
  },
  "devDependencies": {
    "prettier": "3.9.5"
  },
  "packageManager": "yarn@4.17.1"
}
